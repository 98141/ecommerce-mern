NODE_ENV=development
PORT=4000

MONGO_URI=mongodb://localhost:27017/ecommerce-mern

FRONTEND_URL=http://localhost:5173

JWT_ACCESS_SECRET=change-me-access-secret-please
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change-me-refresh-secret-please
JWT_REFRESH_EXPIRES_IN=7d

AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15

EMAIL_VERIFICATION_EXPIRES_MINUTES=60
PASSWORD_RESET_EXPIRES_MINUTES=30

COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# Si la contraseña incluye "#", espacios u otros caracteres especiales,
# enciérrala entre comillas dobles: SEED_ADMIN_PASSWORD="Clave#Segura123"
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=Root
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

LOG_LEVEL=info
